{
  "name": "latex-ja-template",

  // CI（.github/workflows/build-image.yml）が GHCR に公開した
  // ビルド済みイメージを pull する。これにより起動時に TeX Live の
  // インストールが走らず、即座に使える。
  // Dockerfile を変更したら main に push → CI が再ビルド&公開して反映される。
  // 自分のリポジトリ名に合わせてこのイメージ名を書き換えてもよい。
  "image": "ghcr.io/sotetsuk/latex-ja-template:latest",
  "customizations": {
    "vscode": {
      "extensions": [
        "James-Yu.latex-workshop",
        "ms-python.python",
        "streetsidesoftware.code-spell-checker"
      ],
      "settings": {
        "latex-workshop.latex.outDir": "out"
      }
    }
  },
  // 重いセットアップ（numpy/matplotlib の pip + 図生成）は nohup で背景実行し、
  // エディタの起動をブロックしない。進捗・エラーは /tmp/postcreate.log で確認できる。
  // figures/sample.png は git 管理済みなので、セットアップ完了前でも main.tex は即コンパイル可。
  "postCreateCommand": "nohup bash -c 'pip3 install --break-system-packages --no-warn-script-location -r requirements.txt && python3 scripts/make_figure.py && echo \"[postCreate] done\"' > /tmp/postcreate.log 2>&1 < /dev/null &",
  "remoteUser": "vscode"
}
