{
  "name": "latex-ja-template",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "James-Yu.latex-workshop",
        "ms-python.python",
        "streetsidesoftware.code-spell-checker"
      ],
      "settings": {
        "latex-workshop.latex.outDir": "out"
      }
    }
  },
  "postCreateCommand": "pip3 install --break-system-packages --no-warn-script-location -r requirements.txt && python3 scripts/make_figure.py",
  "remoteUser": "vscode"
}
